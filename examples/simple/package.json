{
  "name": "@repo/example-simple",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "bun codegen && bun build src/index.ts --outdir dist --target bun",
    "codegen": "bun-sqlgen generate 'src/**/*.ts' --migrations src/db/migrations",
    "codegen:check": "bun-sqlgen generate 'src/**/*.ts' --migrations src/db/migrations --check",
    "check:types": "bun run --bun tsc"
  },
  "devDependencies": {
    "@repo/bun-sqlgen": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/bun": "^1.3.14",
    "typescript": "catalog:"
  },
  "imports": {
    "#*": "./src/*"
  }
}
