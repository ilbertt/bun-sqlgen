{
  "name": "@repo/example-with-config",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "bun codegen && bun build src/index.ts --outdir dist --target bun",
    "codegen": "bun-sqlgen generate 'src/**/*.ts' --migrations src/db/migrations --package @repo/bun-sqlgen",
    "codegen:check": "bun-sqlgen generate 'src/**/*.ts' --migrations src/db/migrations --package @repo/bun-sqlgen --check",
    "check:types": "bun codegen && bun run --bun tsc"
  },
  "devDependencies": {
    "@electric-sql/pglite": "catalog:",
    "@repo/bun-sqlgen": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/bun": "catalog:",
    "typescript": "catalog:"
  },
  "imports": {
    "#*": "./src/*"
  }
}
