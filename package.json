{
  "name": "bun-sqlgen-monorepo",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "bun run --bun turbo build",
    "check:types": "bun run --bun turbo check:types",
    "check:codestyle": "bun run --bun biome check",
    "check:all": "bun check:types && bun check:codestyle",
    "check:commit-message": "bun run --bun commitlint",
    "fix:codestyle": "bun run --bun biome check --write"
  },
  "workspaces": {
    "packages": [
      "packages/*",
      "examples/*"
    ],
    "catalog": {
      "@electric-sql/pglite": "^0.5.3",
      "@types/bun": "^1.3.14",
      "typescript": "^5.9.3",
      "zod": "^4.4.3"
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-conventional": "^21.1.0",
    "@commitlint/format": "^21.1.0",
    "@commitlint/types": "^21.1.0",
    "@types/bun": "catalog:",
    "typescript": "catalog:",
    "turbo": "^2.10.0"
  },
  "packageManager": "bun@1.3.14"
}
