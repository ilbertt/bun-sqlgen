{
  "name": "@repo/bun-sqlgen",
  "private": true,
  "type": "module",
  "bin": {
    "bun-sqlgen": "./src/cli/main.ts"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "bun": "./src/index.ts"
    },
    "./config": {
      "types": "./src/config.ts",
      "bun": "./src/config.ts"
    }
  },
  "scripts": {
    "bun-sqlgen": "bun run src/cli/main.ts",
    "build": "bun run build.ts",
    "build:lib": "bun run --bun tsc -p tsconfig.build.json",
    "check:types": "bun run --bun tsc",
    "codegen": "parsh-codegen generate --commands src/cli/commands --out src/cli/command-tree.gen.ts --eager"
  },
  "imports": {
    "#*": "./src/*"
  },
  "dependencies": {
    "@electric-sql/pglite": "catalog:",
    "@parshjs/core": "^0.0.10",
    "@repo/bun-sqlgen-core": "workspace:*",
    "zod": "catalog:"
  },
  "peerDependencies": {
    "typescript": "catalog:"
  },
  "devDependencies": {
    "@parshjs/codegen": "^0.0.5",
    "@repo/pack-utils": "workspace:*",
    "@repo/typescript-config": "workspace:*"
  }
}
